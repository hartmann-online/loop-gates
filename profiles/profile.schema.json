{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "loop-gates Budget-Profil",
  "type": "object",
  "required": ["name", "routes", "lighthouse", "budgets", "structure"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "routes": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^/" } },
    "lighthouse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "performance": { "type": "integer", "minimum": 0, "maximum": 100 },
        "seo": { "type": "integer", "minimum": 0, "maximum": 100 },
        "best-practices": { "type": "integer", "minimum": 0, "maximum": 100 },
        "accessibility": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_kb": { "type": "integer", "minimum": 0 },
        "image_kb": { "type": "integer", "minimum": 0 },
        "font_kb": { "type": "integer", "minimum": 0 },
        "js_kb": { "type": "integer", "minimum": 0 }
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require": {
          "type": "array",
          "items": { "enum": ["title", "meta_description", "og_image", "canonical", "lang"] }
        },
        "h1_per_page": { "type": "integer", "minimum": 0 }
      }
    },
    "screenshots": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "routes": { "type": "array", "items": { "type": "string", "pattern": "^/" } },
        "threshold_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
